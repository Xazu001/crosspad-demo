{
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "files.associations": {
    "wrangler.json": "jsonc"
  },
  "oxc.configPath": ".oxlintrc.json",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "stylelint.enable": true,
  "stylelint.configFile": "stylelint.config.js",
  "stylelint.packageManager": "pnpm",
  "stylelint.validate": ["css", "scss"],
  "stylelint.snippet": ["css", "scss"],
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSaveMode": "file",
  "editor.formatOnSave": true,
  "[scss]": {
    "editor.formatOnSave": false
  },
  "[css]": {
    "editor.formatOnSave": false
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.exclude": {
    "polyfills": true,
    ".idea": true,
    "extensions": true,
    "app/components/custom/animations/scroll-reveal.tsx": true,
    "app/style/components/ui": true
  },
  "explorer.fileNesting.patterns": {
    "tsconfig.json": "tsconfig.*.json, tsconfig.*.tsbuildinfo",
    "*.tsx": "${capture}.style.scss, ${capture}.*.tsx, ${capture}.*.style.scss",
    "wrangler.jsonc": "wrangler.*.jsonc",
    "README.md": "README.*.md",
    "drizzle.config.ts": "drizzle.config.*.ts"
  }
}
