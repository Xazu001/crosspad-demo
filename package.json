{
  "name": "crosspad",
  "private": true,
  "type": "module",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp"
    ]
  },
  "scripts": {
    "dev": "cross-env APP_ENV=local react-router dev --force",
    "dev:clean": "node -e \"require('fs').rmSync('.vite',{recursive:true,force:true});require('fs').rmSync('node_modules/.vite',{recursive:true,force:true})\" && pnpm dev",
    "build": "cross-env APP_ENV=prod CLOUDFLARE_ENV=prod react-router build",
    "preview": "npm run build && wrangler --config .build/server/wrangler.json preview",
    "typegen": "wrangler types",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "db:full": "drizzle-kit generate --config=drizzle.config.ts && drizzle-kit migrate --config=drizzle.config.ts",
    "deploy": "pnpm run build && wrangler --config .build/server/wrangler.json deploy",
    "deploy:data": "node -e \"if(!require('fs').existsSync('.build/server/wrangler.json')){console.error('Error: Build required. Run pnpm build first.');process.exit(1)}require('fs').cpSync('public/data','.build/client/data',{recursive:true})\" && wrangler --config .build/server/wrangler.json deploy",
    "cron:test": "curl http://localhost:5173/api/_dev/cron?all=true",
    "fmt": "oxlint --fix",
    "fmt:sort": "prettier . --write --plugin @trivago/prettier-plugin-sort-imports",
    "fmt:style": "stylelint \"**/*.scss\" --fix --config ./stylelint.config.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "script": "tsx scripts/run.ts",
    "build:midifun": "pnpm --filter midifun build",
    "dev:midifun": "pnpm --filter midifun dev",
    "predev": "npx react-router typegen",
    "postinstall": "wrangler types && pnpm --filter midifun install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hono/vite-dev-server": "^0.25.0",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/resize": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "@mui/material": "^7.3.8",
    "@otplib/plugin-base32-scure": "^13.3.0",
    "@otplib/plugin-crypto-noble": "^13.3.0",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.5.0",
    "@remix-run/form-data-parser": "^0.15.0",
    "animejs": "^4.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "hono": "^4.12.7",
    "hono-react-router-adapter": "^0.6.5",
    "isbot": "^5.1.36",
    "jose": "^6.1.3",
    "kysely": "^0.28.11",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.575.0",
    "mailersend": "^2.6.0",
    "otplib": "^13.3.0",
    "postprocessing": "^6.38.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "react-toastify": "^11.0.5",
    "sharp": "^0.34.5",
    "simple-swizzle": "^0.2.4",
    "styled-components": "^6.3.11",
    "three": "^0.183.2",
    "tinycolor2": "^1.6.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.27.0",
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@playwright/test": "^1.58.2",
    "@react-router/dev": "^7.13.1",
    "@stylistic/stylelint-plugin": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/culori": "^4.0.1",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/tinycolor2": "^1.4.6",
    "@vitest/ui": "^4.0.18",
    "citty": "^0.2.1",
    "cloudflare": "^5.2.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "include-media": "^2.0.0",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "postcss-discard-duplicates": "^7.0.2",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0"
  }
}
