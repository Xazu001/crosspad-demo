{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "\\.scss$",
    "^react$",
    "^react-dom",
    "^react-router",
    "^react-router/dom",
    "^@react-router",
    "^@react-three/fiber",
    "^@react-three/drei",
    "^lucide-react",
    "^framer-motion",
    "^gsap",
    "^three",
    "^postprocessing",
    "^culori",
    "^zustand",
    "^class-variance-authority",
    "^clsx",
    "^drizzle-orm",
    "^hono",
    "^jose",
    "^kysely",
    "^[a-zA-Z0-9-]*$",
    "^#/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
