{
  "extends": "./tsconfig.json",
  "include": [
    ".react-router/types/**/*",
    "app/**/*",
    "app/**/.server/**/*",
    "app/**/.client/**/*",
    "server/**/*",
    "shared/**/*",
    "test/**/*",
    "worker-configuration.d.ts",
    "worker.ts",
    "vite-env.d.ts",
    "packages/midifun/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "midifun": ["./packages/midifun/src"],
      "midifun/react": ["./packages/midifun/src/react"],
      "#/*": ["./app/*"],
      "$/*": ["./server/*"],
      "@/*": ["./shared/*"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true
  }
}
